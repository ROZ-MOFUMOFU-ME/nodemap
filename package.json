{
  "name": "nodemap",
  "version": "0.5.0",
  "description": "cryptocurrency geolocation map with a React + TypeScript frontend",
  "main": "server.ts",
  "type": "module",
  "scripts": {
    "start": "tsx server.ts",
    "dev:server": "tsx watch server.ts",
    "dev:client": "vite",
    "dev": "concurrently -n server,client \"npm:dev:server\" \"npm:dev:client\"",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ROZ-MOFUMOFU-ME/nodemap.git"
  },
  "keywords": [
    "cryptocurrency",
    "geoip",
    "geolocation",
    "node",
    "map",
    "node.js",
    "typescript",
    "bitcoin",
    "react",
    "vite",
    "tailwindcss"
  ],
  "author": "ROZ",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ROZ-MOFUMOFU-ME/nodemap/issues"
  },
  "homepage": "https://github.com/ROZ-MOFUMOFU-ME/nodemap",
  "dependencies": {
    "express": "^5.2.1",
    "leaflet": "^1.9.4",
    "node-cache": "^5.1.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/express": "^5.0.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
